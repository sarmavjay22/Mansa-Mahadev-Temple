{
  "entities": {
    "TempleSettings": {
      "title": "Temple Settings",
      "description": "Customizable settings and details for the temple.",
      "type": "object",
      "properties": {
        "templeNameHindi": { "type": "string" },
        "templeNameEnglish": { "type": "string" },
        "templeLogo": { "type": "string" },
        "templeCoverImage": { "type": "string" },
        "templeAddress": { "type": "string" },
        "village": { "type": "string" },
        "city": { "type": "string" },
        "state": { "type": "string" },
        "pincode": { "type": "string" },
        "phone": { "type": "string" },
        "whatsApp": { "type": "string" },
        "email": { "type": "string" },
        "googleMapsLink": { "type": "string" },
        "facebook": { "type": "string" },
        "instagram": { "type": "string" },
        "youtube": { "type": "string" },
        "donationQR": { "type": "string" },
        "upiId": { "type": "string" },
        "morningDarshanTime": { "type": "string" },
        "eveningDarshanTime": { "type": "string" },
        "templeHistory": { "type": "string" },
        "aboutTemple": { "type": "string" },
        "shortDescription": { "type": "string" },
        "primaryThemeColor": { "type": "string" },
        "secondaryThemeColor": { "type": "string" },
        "accentColor": { "type": "string" },
        "footerCopyright": { "type": "string" },
        "developerName": { "type": "string" }
      }
    },
    "TempleGalleryItem": {
      "title": "Temple Gallery Item",
      "description": "An image item in the general temple gallery, classified by category.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "imageUrl": { "type": "string" },
        "caption": { "type": "string" },
        "category": { "type": "string", "enum": ["mandir_parisar", "utsav", "bhaktimay"] },
        "uploadDate": { "type": "string" },
        "isActive": { "type": "boolean" },
        "uploadedAt": { "type": "string" }
      },
      "required": ["imageUrl", "category", "uploadDate", "isActive"]
    }
  },
  "firestore": {
    "settings": {
      "schema": "TempleSettings",
      "description": "Contains temple settings and configurations."
    },
    "temple_gallery": {
      "schema": "TempleGalleryItem",
      "description": "General temple gallery photos categorized by tabs."
    }
  }
}
